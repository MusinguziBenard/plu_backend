    {
      "name": "6. WebRTC Signaling Events (Info)",
      "item": [
        {
          "name": "WebRTC Signaling Flow Documentation",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('🚀 WebRTC Signaling Events (via Socket.IO):');",
                  "console.log('');",
                  "console.log('📡 1. call_user - Initiate a call');",
                  "console.log('   socket.emit(\"call_user\", {');",
                  "console.log('     callerId: \"user_id\",');",
                  "console.log('     calleeId: \"target_user_id\",');",
                  "console.log('     callType: \"audio\" | \"video\",');",
                  "console.log('     roomId: \"unique_room_id\"');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📡 2. accept_call - Accept incoming call');",
                  "console.log('   socket.emit(\"accept_call\", {');",
                  "console.log('     callerId: \"caller_id\",');",
                  "console.log('     calleeId: \"user_id\",');",
                  "console.log('     roomId: \"room_id\"');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📡 3. reject_call - Reject incoming call');",
                  "console.log('   socket.emit(\"reject_call\", {');",
                  "console.log('     callerId: \"caller_id\",');",
                  "console.log('     roomId: \"room_id\"');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📡 4. webrtc_offer - Send SDP offer');",
                  "console.log('   socket.emit(\"webrtc_offer\", {');",
                  "console.log('     roomId: \"room_id\",');",
                  "console.log('     offer: { sdp: \"...\", type: \"offer\" },');",
                  "console.log('     from: \"user_id\",');",
                  "console.log('     to: \"target_user_id\"');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📡 5. webrtc_answer - Send SDP answer');",
                  "console.log('   socket.emit(\"webrtc_answer\", {');",
                  "console.log('     roomId: \"room_id\",');",
                  "console.log('     answer: { sdp: \"...\", type: \"answer\" },');",
                  "console.log('     from: \"user_id\",');",
                  "console.log('     to: \"target_user_id\"');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📡 6. webrtc_ice_candidate - Exchange ICE candidates');",
                  "console.log('   socket.emit(\"webrtc_ice_candidate\", {');",
                  "console.log('     roomId: \"room_id\",');",
                  "console.log('     candidate: { candidate: \"...\", sdpMid: \"0\" },');",
                  "console.log('     from: \"user_id\",');",
                  "console.log('     to: \"target_user_id\"');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📡 7. hang_up - End the call');",
                  "console.log('   socket.emit(\"hang_up\", {');",
                  "console.log('     roomId: \"room_id\",');",
                  "console.log('     userId: \"user_id\"');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📡 8. toggle_media - Mute/unmute audio/video');",
                  "console.log('   socket.emit(\"toggle_media\", {');",
                  "console.log('     roomId: \"room_id\",');",
                  "console.log('     userId: \"user_id\",');",
                  "console.log('     type: \"audio\" | \"video\",');",
                  "console.log('     enabled: true | false');",
                  "console.log('   })');",
                  "console.log('');",
                  "console.log('📱 Test with HTML page or mobile app');",
                  "pm.test(\"Documentation displayed\", function() {",
                  "    pm.expect(true).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/ping",
              "host": ["{{base_url}}"],
              "path": ["ping"]
            }
          }
        }
      ]

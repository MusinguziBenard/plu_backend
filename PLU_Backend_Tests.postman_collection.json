          "name": "Get Notifications",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.length > 0 && response[0].id) {",
                  "    pm.environment.set(\"notification_id\", response[0].id);",
                  "    console.log(\"✅ Notification ID saved:\", response[0].id);",
                  "}"

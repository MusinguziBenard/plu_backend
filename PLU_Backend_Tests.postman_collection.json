{
  "info": {
    "name": "PLU Backend - Complete API Tests",
    "description": "Complete test suite for PLU backend with all endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Join (Register)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"phone\": \"256712345678\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/join",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "join"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.environment.set(\"token\", response.token);",
                  "    console.log(\"✅ Token saved:\", response.token.substring(0, 50) + \"...\");",
                  "}",
                  "if (response.user && response.user.id) {",
                  "    pm.environment.set(\"user_id\", response.user.id);",
                  "}",
                  "pm.test(\"Login successful\", function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(response.token).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"256712345678\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/user/me",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "2. Posts",
      "item": [
        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.post && response.post.id) {",
                  "    pm.environment.set(\"post_id\", response.post.id);",
                  "    console.log(\"✅ Post ID saved:\", response.post.id);",
                  "}",
                  "pm.test(\"Post created successfully\", function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(response.post).to.exist;",
                  "    pm.expect(response.post.id).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test Post {{$timestamp}}\",\n  \"description\": \"This is an automated test post from Postman\",\n  \"media_url\": \"https://picsum.photos/200/300\",\n  \"media_type\": \"image\",\n  \"category\": \"news\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/posts/create",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "create"]
            }
          }
        },
        {
          "name": "Get Feed",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/posts/feed?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "feed"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Post",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/posts/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "{{post_id}}"]
            }
          }
        },
        {
          "name": "Get Post Likes Count",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/posts/{{post_id}}/likes",
              "host": ["{{base_url}}"],
              "path": ["api", "posts", "{{post_id}}", "likes"]

    {
      "name": "2. TURN/STUN Configuration",
      "item": [
        {
          "name": "Get TURN Config (User A)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.test(\"TURN config returned successfully\", function() {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(response.iceServers).to.be.an('array');",
                  "    pm.expect(response.iceServers.length).to.be.at.least(3);",
                  "});",
                  "console.log('✅ TURN config has', response.iceServers.length, 'ICE servers');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
